## One shell variable is used:
##    color -- the color of the marbles for testing
##
## $ pdo-shell -s create.psh -m color <color>

if --null ${save}
   echo must specify contract directory: '-m save <path>'
   exit -1
fi

if --null ${color}
   echo must specify color: '-m color <color>'
   exit -1
fi

## -----------------------------------------------------------------
echo ${_HEADER_} basic asset type tests ${_ENDC_}
## -----------------------------------------------------------------
asset_type -q -f ${save}/${color}_type.pdo describe
asset_type -q -f ${save}/${color}_type.pdo get_asset_type_identifier -s _type_id_

echo ${color} marble type identifier is ${_type_id_}
