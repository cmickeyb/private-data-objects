## One shell variable is used:
##    color -- the color of the marbles for testing
##
## $ pdo-shell -s create.psh -m color <color>

if --null ${save}
   echo must specify contract directory: '-m save <path>'
   exit -1
fi

if --null ${color}
   echo must specify color: '-m color <color>'
   exit -1
fi

## -----------------------------------------------------------------
echo ${_HEADER_} basic vetting organization tests ${_ENDC_}
## -----------------------------------------------------------------
vetting -q -f ${save}/${color}_vetting.pdo get_verifying_key -s _vetting_id_

asset_type -q -f ${save}/${color}_type.pdo get_asset_type_identifier -s _type_id_
vetting -q -f ${save}/${color}_vetting.pdo get_asset_type_identifier -s _tmp_
if --not -e ${_type_id_} ${_tmp_}
   echo ${_ERROR_} type identifier mismatch ${_ENDC_}
   exit -v -1
fi
